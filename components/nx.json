{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "sharedGlobals": [],
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.md"
    ]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "inputs": [
        "production",
        "^production"
      ]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "continuous": true
    },
    "upload": {
      "cache": false
    },
    "monitor": {
      "cache": false,
      "continuous": true
    }
  }
}
