{
  "name": "board-v3-arduino-codex",
  "root": "stepper-rp2040-firmware/src/board_V3_arduino_codex",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/.pio/build"
      ],
      "options": {
        "cwd": "{projectRoot}",
        "command": "pio run -e rp2040_v3_codex"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pio run -e rp2040_v3_codex -t clean"
      }
    },
    "upload": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pio run -e rp2040_v3_codex -t upload"
      }
    },
    "monitor": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pio device monitor -b 115200"
      }
    }
  }
}
